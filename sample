#to find the largest among two numbers:
algorithm:
-get two integers from users as input
-read those integers
-if a greater than b,print a is largest
-if b greater than a,print b is largest
-else print,both are equal

code to find largest number among two numbers:
#include <stdio.h>

int main() {
    int a, b;

    printf("Enter two numbers: ");
    scanf("%d %d", &a, &b);

    if (a > b) {
        printf("%d is the largest number.\n", a);
    } else if (b > a) {
        printf("%d is the largest number.\n", b);
    } else {
        printf("Both numbers are equal.\n");
    }

    return 0;
}           
